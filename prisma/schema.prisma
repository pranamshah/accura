generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      UserRole @default(ADMIN)
  avatar    String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companies CompanyUser[]
  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  VIEWER
  CA
}

model Company {
  id                 String       @id @default(cuid())
  name               String
  legalName          String?
  gstin              String?
  pan                String?
  tan                String?
  cin                String?
  msmeNumber         String?
  address            String?
  city               String?
  state              String?
  stateCode          String?
  pincode            String?
  country            String       @default("India")
  phone              String?
  email              String?
  website            String?
  bankName           String?
  bankAccount        String?
  bankIfsc           String?
  bankBranch         String?
  logoUrl            String?
  financialYearStart Int          @default(4)
  currencySymbol     String       @default("₹")
  currency           String       @default("INR")
  taxRegistered      Boolean      @default(true)
  compositeDealer    Boolean      @default(false)
  businessType       BusinessType @default(PRIVATE_LIMITED)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  users              CompanyUser[]
  groups             LedgerGroup[]
  ledgers            Ledger[]
  vouchers           Voucher[]
  items              Item[]
  units              Unit[]
  godowns            Godown[]
  costCentres        CostCentre[]
  budgets            Budget[]
  gstReturns         GSTReturn[]
  payrollGroups      PayrollGroup[]
  employees          Employee[]
  tdsSections        TDSSection[]
  bankAccounts       BankAccount[]
  caShares           CAShare[]
  aiEntries          AIEntry[]
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      UserRole @default(ACCOUNTANT)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  LLP
  PRIVATE_LIMITED
  PUBLIC_LIMITED
  OPC
  TRUST
  NGO
}

model LedgerGroup {
  id        String        @id @default(cuid())
  companyId String
  name      String
  alias     String?
  parentId  String?
  nature    GroupNature
  isSystem  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    LedgerGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id])
  children  LedgerGroup[] @relation("GroupHierarchy")
  ledgers   Ledger[]
}

enum GroupNature {
  ASSETS
  LIABILITIES
  INCOME
  EXPENSES
}

model Ledger {
  id                 String      @id @default(cuid())
  companyId          String
  groupId            String
  name               String
  alias              String?
  openingBalance     Float       @default(0)
  openingBalanceType BalanceType @default(DEBIT)
  gstin              String?
  pan                String?
  tan                String?
  mobileNo           String?
  email              String?
  address            String?
  city               String?
  state              String?
  stateCode          String?
  pincode            String?
  creditLimit        Float?
  creditDays         Int?
  isParty            Boolean     @default(false)
  partyType          PartyType?
  gstType            GSTType?
  tdsApplicable      Boolean     @default(false)
  tdsSectionId       String?
  bankName           String?
  bankAccount        String?
  bankIfsc           String?
  isActive           Boolean     @default(true)
  isSystem           Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  company            Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  group              LedgerGroup @relation(fields: [groupId], references: [id])
  voucherEntries     VoucherEntry[]
  tdsSection         TDSSection? @relation(fields: [tdsSectionId], references: [id])

  @@unique([companyId, name])
}

enum BalanceType {
  DEBIT
  CREDIT
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum GSTType {
  REGULAR
  COMPOSITION
  UNREGISTERED
  CONSUMER
  OVERSEAS
  SEZ
}

model Voucher {
  id             String        @id @default(cuid())
  companyId      String
  type           VoucherType
  number         String
  date           DateTime
  narration      String?
  reference      String?
  totalAmount    Float         @default(0)
  status         VoucherStatus @default(ACTIVE)
  isPosted       Boolean       @default(true)
  gstApplicable  Boolean       @default(false)
  gstType        String?
  placeOfSupply  String?
  reverseCharge  Boolean       @default(false)
  eInvoiceIRN    String?
  eInvoiceQR     String?
  eWayBillNo     String?
  eWayBillExpiry DateTime?
  costCentreId   String?
  aiGenerated    Boolean       @default(false)
  attachments    String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries        VoucherEntry[]
  gstLines       GSTLine[]
  tdsEntries     TDSEntry[]
  costCentre     CostCentre?   @relation(fields: [costCentreId], references: [id])
  inventoryLines InventoryLine[]

  @@unique([companyId, type, number])
}

enum VoucherType {
  SALES
  PURCHASE
  PAYMENT
  RECEIPT
  JOURNAL
  CONTRA
  DEBIT_NOTE
  CREDIT_NOTE
  SALES_ORDER
  PURCHASE_ORDER
  DELIVERY_NOTE
  GOODS_RECEIPT
  OPENING_BALANCE
  PAYROLL
}

enum VoucherStatus {
  ACTIVE
  CANCELLED
  DRAFT
}

model VoucherEntry {
  id        String    @id @default(cuid())
  voucherId String
  ledgerId  String
  type      EntryType
  amount    Float
  narration String?
  billRef   String?
  billDate  DateTime?
  createdAt DateTime  @default(now())
  voucher   Voucher   @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  ledger    Ledger    @relation(fields: [ledgerId], references: [id])
}

enum EntryType {
  DEBIT
  CREDIT
}

model GSTLine {
  id           String  @id @default(cuid())
  voucherId    String
  hsnCode      String?
  description  String?
  quantity     Float?
  rate         Float?
  taxableValue Float
  igstRate     Float   @default(0)
  cgstRate     Float   @default(0)
  sgstRate     Float   @default(0)
  cessRate     Float   @default(0)
  igstAmount   Float   @default(0)
  cgstAmount   Float   @default(0)
  sgstAmount   Float   @default(0)
  cessAmount   Float   @default(0)
  totalTax     Float   @default(0)
  voucher      Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

model GSTReturn {
  id        String        @id @default(cuid())
  companyId String
  type      GSTReturnType
  period    String
  year      Int
  status    ReturnStatus  @default(PENDING)
  filedOn   DateTime?
  arn       String?
  jsonData  Json?
  createdAt DateTime      @default(now())
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum GSTReturnType {
  GSTR1
  GSTR2B
  GSTR3B
  GSTR9
  GSTR9C
  CMP08
}

enum ReturnStatus {
  PENDING
  DRAFT
  FILED
  VERIFIED
}

model Item {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  alias           String?
  code            String?
  hsnCode         String?
  sacCode         String?
  unitId          String?
  category        String?
  igstRate        Float    @default(0)
  cgstRate        Float    @default(0)
  sgstRate        Float    @default(0)
  cessRate        Float    @default(0)
  openingStock    Float    @default(0)
  openingRate     Float    @default(0)
  reorderLevel    Float?
  maxStock        Float?
  isBatchEnabled  Boolean  @default(false)
  isSerialEnabled Boolean  @default(false)
  isActive        Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unit            Unit?    @relation(fields: [unitId], references: [id])
  inventoryLines  InventoryLine[]

  @@unique([companyId, name])
}

model Unit {
  id        String  @id @default(cuid())
  companyId String
  name      String
  symbol    String
  isSystem  Boolean @default(false)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items     Item[]
}

model Godown {
  id             String         @id @default(cuid())
  companyId      String
  name           String
  address        String?
  isMain         Boolean        @default(false)
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventoryLines InventoryLine[]
}

model InventoryLine {
  id        String  @id @default(cuid())
  voucherId String
  itemId    String
  godownId  String?
  batchNo   String?
  serialNo  String?
  quantity  Float
  rate      Float
  amount    Float
  discount  Float   @default(0)
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  item      Item    @relation(fields: [itemId], references: [id])
  godown    Godown? @relation(fields: [godownId], references: [id])
}

model CostCentre {
  id        String       @id @default(cuid())
  companyId String
  name      String
  parentId  String?
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    CostCentre?  @relation("CostHierarchy", fields: [parentId], references: [id])
  children  CostCentre[] @relation("CostHierarchy")
  vouchers  Voucher[]
}

model Budget {
  id            String       @id @default(cuid())
  companyId     String
  name          String
  financialYear String
  periodType    String       @default("MONTHLY")
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines         BudgetLine[]
}

model BudgetLine {
  id       String  @id @default(cuid())
  budgetId String
  ledgerId String?
  period   String
  amount   Float
  budget   Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
}

model TDSSection {
  id             String     @id @default(cuid())
  companyId      String
  section        String
  description    String?
  rate           Float
  thresholdLimit Float      @default(0)
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ledgers        Ledger[]
  tdsEntries     TDSEntry[]
}

model TDSEntry {
  id            String     @id @default(cuid())
  voucherId     String
  sectionId     String
  taxableAmount Float
  tdsAmount     Float
  challanNo     String?
  challanDate   DateTime?
  deposited     Boolean    @default(false)
  voucher       Voucher    @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  section       TDSSection @relation(fields: [sectionId], references: [id])
}

model PayrollGroup {
  id            String     @id @default(cuid())
  companyId     String
  name          String
  pfApplicable  Boolean    @default(false)
  esiApplicable Boolean    @default(false)
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees     Employee[]
}

model Employee {
  id             String        @id @default(cuid())
  companyId      String
  groupId        String?
  code           String?
  name           String
  designation    String?
  department     String?
  dateOfJoining  DateTime?
  dateOfLeaving  DateTime?
  pan            String?
  aadhaar        String?
  uan            String?
  esicNo         String?
  bankAccount    String?
  bankIfsc       String?
  basicSalary    Float         @default(0)
  hra            Float         @default(0)
  conveyance     Float         @default(0)
  special        Float         @default(0)
  pfApplicable   Boolean       @default(false)
  esiApplicable  Boolean       @default(false)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  group          PayrollGroup? @relation(fields: [groupId], references: [id])
  payrollEntries PayrollEntry[]
}

model PayrollEntry {
  id              String    @id @default(cuid())
  employeeId      String
  month           Int
  year            Int
  workingDays     Float     @default(26)
  presentDays     Float     @default(26)
  basic           Float
  hra             Float     @default(0)
  conveyance      Float     @default(0)
  special         Float     @default(0)
  otherEarnings   Float     @default(0)
  grossSalary     Float
  pfEmployee      Float     @default(0)
  esiEmployee     Float     @default(0)
  tds             Float     @default(0)
  otherDeductions Float     @default(0)
  netSalary       Float
  pfEmployer      Float     @default(0)
  esiEmployer     Float     @default(0)
  isPaid          Boolean   @default(false)
  paidOn          DateTime?
  createdAt       DateTime  @default(now())
  employee        Employee  @relation(fields: [employeeId], references: [id])
}

model BankAccount {
  id              String               @id @default(cuid())
  companyId       String
  name            String
  accountNo       String
  bankName        String
  ifsc            String?
  branch          String?
  openingBalance  Float                @default(0)
  createdAt       DateTime             @default(now())
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reconciliations BankReconciliation[]
}

model BankReconciliation {
  id             String      @id @default(cuid())
  bankAccountId  String
  voucherId      String?
  date           DateTime
  description    String?
  amount         Float
  type           EntryType
  isReconciled   Boolean     @default(false)
  reconciledDate DateTime?
  bankAccount    BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

model CAShare {
  id          String    @id @default(cuid())
  companyId   String
  caEmail     String
  accessLevel CAAccess  @default(READ)
  sharedBy    String
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  token       String    @unique @default(cuid())
  createdAt   DateTime  @default(now())
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum CAAccess {
  READ
  FULL
}

model AIEntry {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  prompt    String   @db.Text
  response  String   @db.Text
  voucherId String?
  type      AIType
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum AIType {
  ENTRY_SUGGESTION
  NARRATION
  RECONCILIATION
  ANOMALY_DETECTION
  REPORT_INSIGHT
  LEDGER_CLASSIFICATION
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  companyId String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
